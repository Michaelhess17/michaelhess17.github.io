# ==============================================================================
# Hugo Build Artifacts
# ==============================================================================
# Files and directories generated by Hugo during the build process
# These should not be committed as they are regenerated on each build

# Public directory - contains the built static site
public/

# Hugo build lock file - temporary file created during builds
.hugo_build.lock

# Resources directory - Hugo-generated cached resources
# (resized images, processed CSS, etc.)
# Uncomment the next line if you want to ignore the entire resources directory
# resources/

# Generated resources that change frequently
resources/_gen/

# ==============================================================================
# Development Tools
# ==============================================================================

# Node modules (if using npm for additional tools)
node_modules/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ==============================================================================
# Operating System Files
# ==============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
.directory

# ==============================================================================
# Temporary and Backup Files
# ==============================================================================

# Temporary files
*.tmp
*.temp
*.bak
*.log

# Backup files created during editing
hugo.toml.backup
*.toml.backup
